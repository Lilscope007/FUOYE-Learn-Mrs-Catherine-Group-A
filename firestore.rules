rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - xp: number (required)
    //   - streak: number (required)
    //   - lastPracticeDate: string (optional)
    //   - currentCourseId: string (optional)
    //   - role: string (required, 'user' or 'admin')
    //
    // Collection: courses
    // Document ID: courseId
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - language: string (required)
    //   - icon: string (optional)
    //
    // Collection: units
    // Document ID: unitId
    // Fields:
    //   - courseId: string (required)
    //   - title: string (required)
    //   - description: string (optional)
    //   - order: number (required)
    //
    // Collection: lessons
    // Document ID: lessonId
    // Fields:
    //   - unitId: string (required)
    //   - title: string (required)
    //   - topic: string (required)
    //   - order: number (required)
    //   - xpReward: number (required)
    //
    // Collection: userProgress
    // Document ID: userId
    // Fields:
    //   - userId: string (required)
    //   - completedLessons: list of strings (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "lilscope01@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'xp', 'streak', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.xp is number && data.xp >= 0 &&
             data.streak is number && data.streak >= 0 &&
             data.role in ['user', 'admin'];
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['title', 'language']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.language is string && data.language.size() > 0 && data.language.size() < 50;
    }

    function isValidUnit(data) {
      return data.keys().hasAll(['courseId', 'title', 'order']) &&
             data.courseId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.order is number;
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['unitId', 'title', 'topic', 'order', 'xpReward']) &&
             data.unitId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.topic is string && data.topic.size() > 0 && data.topic.size() < 200 &&
             data.order is number &&
             data.xpReward is number && data.xpReward >= 0;
    }

    function isValidUserProgress(data) {
      return data.keys().hasAll(['userId', 'completedLessons']) &&
             data.userId is string &&
             data.completedLessons is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) &&
                    (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) &&
                    (request.resource.data.role == resource.data.role || isAdmin()) &&
                    request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() && (request.method == 'delete' || isValidCourse(request.resource.data));
    }

    match /units/{unitId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() && (request.method == 'delete' || isValidUnit(request.resource.data));
    }

    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() && (request.method == 'delete' || isValidLesson(request.resource.data));
    }

    match /userProgress/{progressId} {
      allow read: if isOwner(progressId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(progressId) && isValidUserProgress(request.resource.data) &&
                    request.resource.data.userId == progressId;
      allow update: if isAuthenticated() && isOwner(progressId) && isValidUserProgress(request.resource.data) &&
                    request.resource.data.userId == resource.data.userId;
      allow delete: if isAdmin();
    }
  }
}
